# OBRIGATÓRIO em produção — gerar com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=sua-chave-secreta-aqui-minimo-50-caracteres-aleatorios

# Mudar para False em produção
DEBUG=True

# Em produção: usar o domínio real, ex: meusite.ao,www.meusite.ao
ALLOWED_HOSTS=localhost,127.0.0.1

# n8n — URL do webhook que recebe o CV para análise
N8N_WEBHOOK_CV_URL=http://localhost:5678/webhook/cv-analysis

# n8n — URL do webhook que calcula score de candidatura
N8N_WEBHOOK_SCORE_URL=http://localhost:5678/webhook/job-scoring

# OBRIGATÓRIO — token partilhado entre Django e n8n (sem este valor, os callbacks são bloqueados)
# Gerar com: python -c "import secrets; print(secrets.token_hex(32))"
N8N_CALLBACK_SECRET=kubuka-secret-token-2025

# URL base do Django (usado nos callbacks do n8n)
DJANGO_BASE_URL=http://localhost:8000

# Email (deixar EMAIL_BACKEND em branco em produção para usar SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=teu-email@gmail.com
EMAIL_HOST_PASSWORD=app-password-aqui
DEFAULT_FROM_EMAIL=KUBUKA <noreply@kubuka.ao>

# Variáveis legadas (manter por compatibilidade)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/cv-analysis
N8N_SECRET_TOKEN=token-secreto-n8n-aqui
CALLBACK_SECRET=token-secreto-callback-aqui
